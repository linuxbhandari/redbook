root@kube-master:~# cat > test.tyml  
apiVersion: v1                          
kind: Pod                     				<== Kind is Instruction type (it is case-sensitive)
  creationTimestamp: null
  labels:
    run: test
  name: test
spec:
  containers:
  - image: docker.io/nginx
    name: test
    resources: {}
  dnsPolicy: ClusterFirst
  restartPolicy: Always
status: {}

