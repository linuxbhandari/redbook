Secrets:
=======
2 types of secrets
 1) generic : for simgple value like password, token, single string.
 2) tls : certificates, key=values,


# kubectl create secret generic super-secret --from-literal=mypass=redhat
# kubectl create secret generic db-secret   --from-literal=username=admin   --from-literal=password=pass123
# kubectl create secret generic super-secret --from-literal=mypass=redhat --from-literal=myuser=root
# kubectl create secret generic super-secret --from-literal=mypass=redhat --from-literal=myuser=root --dry-run=client -o yaml

# kubectl get secrets

