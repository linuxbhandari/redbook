ConfigMap: Do the same work as secret does.
but
secret : hold value in encrypted format.
configMap : hold value in plain text.
     => wants to share data via configMap, so that it will visible for all containers.


root@kube-master:~/deployments/k8s# kubectl create configmap super-config --from-literal=nfs-server=192.168.122.215
configmap/super-config created


root@kube-master:~/deployments/k8s# kubectl get configmaps super-config -o yaml
apiVersion: v1
data:
  nfs-server: 192.168.122.215        <<<<< hold data in plain text
kind: ConfigMap
metadata:
  creationTimestamp: "2024-03-29T04:39:35Z"
  name: super-config
  namespace: default
  resourceVersion: "96779"
  uid: d3c40cc8-5ce6-4bb1-a6d9-b0ad53482379

# kubectl create configmap nginx-config --from-file=default-nginx.conf       # configmap for file store
# rm -rf default-nginx.conf                                                  # after create configmap for file. you can remove file from system.


Now how to use it.
=================

# kubectl run test --image=nginx --dry-run=client -o yaml > pod.yml

root@kube-master: ~# cat pod.yml
apiVersion: v1
kind: Pod
metadata:
  creationTimestamp: null
  labels:
    run: test
  name: test
spec:
  containers:
  - image: nginx
    name: test
    envFrom:
      - configMapRef:
              name: super-config


