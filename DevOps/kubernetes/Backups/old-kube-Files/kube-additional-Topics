IQ) How we can use secret value?
   we have two way to do this
   1) as envirnoment variable
   2) as a volume

root@kube-master:~# kubectl create deployment mysql-dep --image=mysql:5.6 --dry-run=client -o yaml > db.yml

root@kube-master:~# cat db.yml 
apiVersion: apps/v1
kind: Deployment
metadata:
  creationTimestamp: null
  labels:
    app: mysql-dep
  name: mysql-dep
spec:
  replicas: 1
  selector:
    matchLabels:
      app: mysql-dep
  strategy: {}
  template:
    metadata:
      creationTimestamp: null
      labels:
        app: mysql-dep
    spec:
      containers:
      - image: mysql:5.6
        name: mysql
        env:
          - name: MYSQL_ROOT_PASSWORD
            valueFrom:
               secretKeyRef:
                       name: super-secret
                       key: mypass

